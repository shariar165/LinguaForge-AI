# Supabase project (Settings -> API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Settings -> API -> JWT Settings -> JWT Secret (legacy HS256 secret)
SUPABASE_JWT_SECRET=your-jwt-secret

# Groq API key (free at https://console.groq.com/keys) — needed only for the AI tutor
GROQ_API_KEY=your-groq-api-key
# Optional overrides (defaults shown)
# AI_BASE_URL=https://api.groq.com/openai/v1
# AI_MODEL=llama-3.3-70b-versatile
# AI_FALLBACK_MODEL=llama-3.1-8b-instant

# Comma-separated list of allowed browser origins
FRONTEND_ORIGINS=http://localhost:3000

# Per-user daily AI message cap (cost control)
DAILY_AI_MESSAGE_LIMIT=30
